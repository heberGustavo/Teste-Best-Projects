                            <td>34090239</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger">Excluir</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script src="~/js/home/index.js" asp-append-version="true"></script>