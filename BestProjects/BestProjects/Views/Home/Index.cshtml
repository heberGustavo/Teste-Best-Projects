@{
    ViewData["Title"] = "Home Page";
}

<div class="row">

    <div class="col-md-12">

        <div class="card">
            <div class="card-body">
                <h4>Novo Contato</h4>
                <hr />


                <form>
                    <div class="form-group">
                        <label for="nome">Nome </label>
                        <input type="text" class="form-control" id="nome" placeholder="Ex: Heber Gustavo">
                    </div>
                    <div class="form-group">
                        <label for="telefone">Telefono Res. </label>
                        <input type="text" class="form-control" id="telefone" placeholder="Ex: (00) 0000-0000">
                    </div>
                    <div class="form-group">
                        <label for="celular">Celular </label>
                        <input type="text" class="form-control" id="celular" placeholder="Ex: (00) 00000-0000">
                    </div>
                    <div class="form-group d-flex justify-content-center mt-4 mb-0">
                        <button onclick="CadastrarContato()" type="button" class="btn btn-outline-primary">Adicionar</button>
                    </div>
                </form>

                <hr />

                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Nome</th>
                            <th scope="col">Telefone Res.</th>
                            <th scope="col">Celular</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
